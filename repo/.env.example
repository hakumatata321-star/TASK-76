# FleetReserve Operations Suite — secret configuration template
# Copy this file to .env, fill in real values, then run:
#   docker-compose --env-file .env up
#
# Generate unique secrets with:
#   openssl rand -hex 32

# Key used for AES-GCM backup encryption (must be >= 32 characters, unique per deployment)
ENCRYPTION_KEY=<replace-with-openssl-rand-hex-32-output>

# Key used for HMAC-signed bearer tokens (must be >= 32 characters, unique per deployment)
HMAC_SECRET=<replace-with-openssl-rand-hex-32-output>

# Optional: override the default bootstrap admin password used on first run.
# If unset, the well-known default from the README is used.
# Set this to a strong unique value before any non-development deployment.
# BOOTSTRAP_ADMIN_PASSWORD=<replace-with-strong-password>
